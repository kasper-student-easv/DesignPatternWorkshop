<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="10" xmlns:fx="http://javafx.com/fxml"
      fx:controller="dk.easv.designpatternworkshop.MainController">

    <padding>
        <Insets top="15" right="15" bottom="15" left="15"/>
    </padding>

    <!-- Title -->
    <Label text="ARDF Fox Serial Configurator"
           style="-fx-font-size:18px; -fx-font-weight:bold;"/>
    <Label text="Built for RFzero™ www.rfzero.net"/>

    <!-- COM Port Row -->
    <HBox spacing="10">
        <Label text="COM port:"/>
        <ComboBox fx:id="comPort" prefWidth="150"/>
        <Button text="Reload"/>
        <Button text="Connect..."/>
        <Button text="Disconnect..." disable="true"/>
    </HBox>

    <!-- Main Form -->
    <GridPane hgap="10" vgap="8">

        <columnConstraints>
            <ColumnConstraints percentWidth="45"/>
            <ColumnConstraints percentWidth="55"/>
        </columnConstraints>

        <!-- Row 1 -->
        <Label text="Test begin time:" GridPane.rowIndex="0"/>
        <TextField GridPane.columnIndex="1" GridPane.rowIndex="0"/>

        <Label text="Hunting begin time:" GridPane.rowIndex="1"/>
        <TextField GridPane.columnIndex="1" GridPane.rowIndex="1"/>

        <Label text="Hunting stop time:" GridPane.rowIndex="2"/>
        <TextField GridPane.columnIndex="1" GridPane.rowIndex="2"/>

        <Label text="Fox ID:" GridPane.rowIndex="3"/>
        <ComboBox GridPane.columnIndex="1" GridPane.rowIndex="3"/>

        <Label text="Nominal frequency in Hz:" GridPane.rowIndex="4"/>
        <TextField GridPane.columnIndex="1" GridPane.rowIndex="4"/>

        <Label text="Alternative Fox ID:" GridPane.rowIndex="5"/>
        <ComboBox GridPane.columnIndex="1" GridPane.rowIndex="5"/>

        <Label text="Alternative frequency in Hz:" GridPane.rowIndex="6"/>
        <TextField GridPane.columnIndex="1" GridPane.rowIndex="6"/>

        <Label text="Repeat period (minutes):" GridPane.rowIndex="7"/>
        <ComboBox GridPane.columnIndex="1" GridPane.rowIndex="7"/>

        <Label text="Competition style:" GridPane.rowIndex="8"/>
        <ComboBox GridPane.columnIndex="1" GridPane.rowIndex="8"/>

        <Label text="Reference start frequency in Hz:" GridPane.rowIndex="9"/>
        <TextField GridPane.columnIndex="1" GridPane.rowIndex="9"/>

        <Label text="Echo GPS data to USB port:" GridPane.rowIndex="10"/>
        <ComboBox GridPane.columnIndex="1" GridPane.rowIndex="10"/>

        <!-- Offset UTC -->
        <Label text="Offset to UTC Hours / Minutes:" GridPane.rowIndex="11"/>
        <HBox spacing="5" GridPane.columnIndex="1" GridPane.rowIndex="11">
            <Label text="Hours"/>
            <TextField prefWidth="60"/>
            <Label text="Minutes"/>
            <TextField prefWidth="60"/>
        </HBox>

        <Label text="Keying style:" GridPane.rowIndex="12"/>
        <ComboBox GridPane.columnIndex="1" GridPane.rowIndex="12"/>

        <!-- CW Speed -->
        <Label text="CW speed:" GridPane.rowIndex="13"/>
        <HBox spacing="5" GridPane.columnIndex="1" GridPane.rowIndex="13">
            <TextField promptText="WPM"/>
            <Label text="/"/>
            <TextField promptText="LPM"/>
        </HBox>

        <Label text="Fox call (max 15 characters):" GridPane.rowIndex="14"/>
        <TextField GridPane.columnIndex="1" GridPane.rowIndex="14"/>

    </GridPane>

    <!-- Buttons -->
    <HBox spacing="10">
        <Button text="Send config..." style="-fx-background-color:#81C784;"/>
        <Button text="Read result" style="-fx-background-color:#FFD54F;"/>
        <Button text="Reset result" style="-fx-background-color:#64B5F6;"/>
        <Button text="Load template..." style="-fx-background-color:#BA68C8;"/>
    </HBox>

    <!-- Status -->
    <Label text="Status: Disconnected    Last action:"/>

</VBox>
